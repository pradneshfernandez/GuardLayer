# Claude API key — used by extraction/ to parse entity mentions from LLM responses
ANTHROPIC_API_KEY=

# VOYGR business-status API — blank key means verification returns "uncertain"
VOYGR_API_KEY=
VOYGR_API_BASE_URL=https://dev.voygr.tech
# Free-tier rate limit, requests per minute
VOYGR_RATE_LIMIT_RPM=10

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=guardlayer
POSTGRES_USER=guardlayer
POSTGRES_PASSWORD=guardlayer

# Redis connection
REDIS_URL=redis://localhost:6379

# Confidence threshold (0.0-1.0) below which needs_enrichment is flagged true
CONFIDENCE_THRESHOLD=0.70
